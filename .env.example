# Копирај во .env и пополни:
#   copy .env.example .env

DATABASE_URL="file:./dev.db"
# Минимум 32 знаци за продукција (openssl rand -base64 32)
AUTH_SECRET="замени-со-случаен-дуг-стринг-минимум-триесет-два-знаци"
AUTH_TRUST_HOST="true"

# За вистинска страница за плаќање со картичка: валиден таен клуч (подолу) + NEXT_PUBLIC_APP_URL.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Само NODE_ENV=development: ако е true и НЕМА валиден таен клуч, плаќањето се симулира БЕЗ картичка.
# За production / вистинска картичка: false и задолжително валиден тест или live клуч од доставувачот.
STRIPE_DEV_MOCK="false"
# Без валиден таен клуч: „Додај бизнис“ и „Пакети“ нудат форма за активирање на пакет без картичка (демо).
# Опционално: потпис за webhook по успешно плаќање (продукција)
STRIPE_WEBHOOK_SECRET="whsec_..."
