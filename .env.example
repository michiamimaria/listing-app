# Копирај во .env и пополни:
#   copy .env.example .env

DATABASE_URL="file:./dev.db"
# Минимум 32 знаци за продукција (openssl rand -base64 32)
AUTH_SECRET="замени-со-случаен-дуг-стринг-минимум-триесет-два-знаци"
AUTH_TRUST_HOST="true"

# Stripe — за копчињата „Плати со Stripe“ додади STRIPE_SECRET_KEY и NEXT_PUBLIC_APP_URL во .env.
# За симулација без картичка во dev, види STRIPE_DEV_MOCK подолу (стави true само локално).
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_APP_URL="http://localhost:3000"
STRIPE_DEV_MOCK="false"
# Опционално: webhook за checkout.session.completed (продукција)
STRIPE_WEBHOOK_SECRET="whsec_..."
