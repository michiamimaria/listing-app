generator client {
  provider = "prisma-client-js"
  // Надвор од node_modules — OneDrive/антивирус често заклучуваат .dll при rename во node_modules/.prisma
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  createdAt    DateTime   @default(now())
  listings     Listing[]
  payments     Payment[]
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSessionId String   @unique
  packageKey      String
  amountMkd       Int
  validUntil      DateTime
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([packageKey])
}

model Listing {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  categorySlug    String
  subcategorySlug String
  city            String
  phone           String
  website         String?
  description     String   @default("")
  listingPackage  String   @default("free")
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  priceTier       Int      @default(1)
  imageCount      Int      @default(0)
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([categorySlug])
}
